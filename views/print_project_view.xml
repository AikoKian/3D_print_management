<odoo>
    <record id="view_print_project_tree" model="ir.ui.view">
        <field name="name">print.project.tree</field>
        <field name="model">print.project</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-primary="state == 'review'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="total_calculated_price" string="Sugerido"/>
                <field name="final_price" string="Precio Real" decoration-bf="1"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-primary="state == 'review'" decoration-success="state == 'done'"/>
            </tree>
        </field>
    </record>

    <record id="view_print_project_form" model="ir.ui.view">
        <field name="name">print.project.form</field>
        <field name="model">print.project</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_check_availability" string="Comprobar Viabilidad" type="object" class="btn-secondary" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_cancel" string="Cancelar" type="object" confirm="¿Seguro?" attrs="{'invisible': [('state', 'in', ['done', 'cancel'])]}"/>
                    <button name="action_start_printing" string="Iniciar Impresión" type="object" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_submit_for_review" string="Enviar a Revisión" type="object" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'in_progress')]}"/>
                    <button name="action_confirm_done" string="Confirmar y Cerrar" type="object" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'review')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,review,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_sale_order" class="oe_stat_button" icon="fa-usd" attrs="{'invisible': [('sale_order_id', '=', False)]}">
                            <div class="o_stat_info"><span class="o_stat_text">Ver Presupuesto</span></div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre del Proyecto"/></h1>
                    </div>
                    <group>
                        <group string="Información y Tiempos">
                            <field name="partner_id"/>
                            <field name="printer_id" options="{'no_create': True}"/>
                            <field name="estimated_hours" widget="float_time"/>
                            <field name="real_hours" 
                            widget="float_time" 
                            attrs="{
                                'required': [('state', '=', 'in_progress')],
                                'readonly': [('state', '!=', 'in_progress')]
                            }"/>
                            <field name="labor_hours" widget="float_time"/>
                            <field name="labor_rate" widget="monetary"/>
                        </group>
                        <group string="Liquidación y Costeo">
                            <field name="total_calculated_price" widget="monetary" readonly="1" style="color: #7f8c8d; font-style: italic;"/>
                            <field name="final_price" widget="monetary" style="font-size: 1.4em; font-weight: bold; color: #2ecc71;"/>
                            <field name="price_notes" placeholder="Notas sobre el precio o descuentos..."/>
                            <field name="sale_order_id" readonly="1" attrs="{'invisible': [('sale_order_id', '=', False)]}"/>
                        </group>
                        <group string="Documentación Técnica">
                            <field name="stl_filename" invisible="1"/>
                            
                            <field name="stl_file" 
                                filename="stl_filename" 
                                widget="binary" 
                                string="Modelo 3D (STL)"/>

                            <field name="technical_notes" 
                            placeholder="Ej: Altura de capa 0.2mm, soportes en árbol, relleno al 15%..."
                            nolabel="0"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Materiales">
                            <field name="line_ids">
                                <tree editable="bottom" decoration-danger="inventory_status == 'insufficient'" decoration-success="inventory_status == 'ok'">
                                    <field name="material_id"/>
                                    <field name="stock_available"/>
                                    <field name="weight_needed"/>
                                    <field name="inventory_status" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_print_project" model="ir.actions.act_window">
        <field name="name">Proyectos de Impresión</field>
        <field name="res_model">print.project</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_print_project" name="Proyectos" parent="menu_print_root" action="action_print_project" sequence="10"/>
</odoo>