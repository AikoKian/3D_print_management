<odoo>
    <record model="ir.module.category" id="module_category_print_3d">
        <field name="name">Impresión 3D</field>
        <field name="description">Niveles de acceso para el gestor de proyecto 3D.</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_print_user" model="res.groups">
        <field name="name">Operador</field>
        <field name="category_id" ref="module_category_print_3d"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_print_manager" model="res.groups">
        <field name="name">Administrador</field>
        <field name="category_id" ref="module_category_print_3d"/>
        <field name="implied_ids" eval="[(4, ref('group_print_user'))]"/>
    </record>
</odoo>