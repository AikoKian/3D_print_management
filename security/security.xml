<odoo>
    <data noupdate="1">
        <record model="ir.module.category" id="module_category_print_management">
            <field name="name">Impresión 3D</field>
            <field name="description">Niveles de acceso para el módulo de Impresión 3D.</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_print_operator" model="res.groups">
            <field name="name">Operador</field>
            <field name="category_id" ref="module_category_print_management"/>
        </record>

        <record id="group_print_manager" model="res.groups">
            <field name="name">Administrador</field>
            <field name="category_id" ref="module_category_print_management"/>
            <field name="implied_ids" eval="[(4, ref('group_print_operator'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>